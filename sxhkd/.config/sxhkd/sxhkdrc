# Open Emacs client
control + alt + Return
    emacsclient -c

# Open web browser
control + shift + Return
    librewolf

# Open application launcher
alt + space
    rofi -modi "window,run,search:~/.config/rofi/scripts/web_search.sh" -show run

# Open Org Mode capture frame
shift + alt + c
    emacsclient -e '(prot-window-popup-org-capture)'

# Clipboard history
alt + i
    rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'
