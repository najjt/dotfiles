# Open Emacs client
control + alt + Return
    emacsclient -c -n -e '(recentf-open-files)'

# Open web browser
control + shift + Return
    qutebrowser

# Open application launcher
alt + r
    rofi -modi "run,search:~/.config/rofi/scripts/web_search.sh,power:~/.config/rofi/scripts/rofi-power-menu" -show run

# Open Org Mode capture frame
shift + alt + c
    emacsclient -e '(prot-window-popup-org-capture)'

# Clipboard history
alt + i
    rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'
