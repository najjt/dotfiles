# Open Emacs client
super + m
    emacsclient -c

# Open terminal emulator
super + t
    alacritty

# Open web browser
super + n
    firefox &

# Open application launcher
super + b
    rofi -modi "drun" -show drun -show-icons

# Clipboard history
super + i
    rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'

# Open Org Mode capture frame
super + c
    emacsclient -e '(prot-window-popup-org-capture)'

# Run word definition script
super + d
    define
