# Open Emacs client
super + m
    emacsclient -cn

# Open web browser
super + n
    qutebrowser

# Open application launcher
super + d
    dmenu_run -fn 'Unifont-12'

# Clipboard history
super + i
    dmenu_clip

# Open Org Mode capture frame
super + c
    emacsclient -e '(prot-window-popup-org-capture)'
