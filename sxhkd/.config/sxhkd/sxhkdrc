# Open Emacs client
control + Return
    emacsclient -n -c -F "'(fullscreen . maximized)"

# Open web browser
control + shift + Return
    qutebrowser

# Open terminal emulator
alt + Return
    alacritty

# Open application launcher
super + space
    rofi -show combi -modes combi -combi-modes "window,drun,run"

# Open Org Mode capture frame
shift + alt + c
    emacsclient -e '(prot-window-popup-org-capture)'

# Clipboard history
super + c
    rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'
