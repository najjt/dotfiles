#
# General
#

# Modifier key
set $mod Mod4

focus_follows_mouse yes

# Scripts directory
set $sd ~/scripts

# Background processes
exec --no-startup-id $sd/autostart

# Don't move to opposite window if moving focus towards screen border
focus_wrapping no

workspace_layout tabbed

# Workspace monitor assignment
workspace 1 output HDMI-2 eDP-1
workspace 2 output HDMI-2 eDP-1
workspace 3 output HDMI-2 eDP-1
workspace 7 output eDP-1
workspace 8 output eDP-1
workspace 9 output eDP-1

#
# Appearance
#

# Font
set $font sans
set $font_size 10

font pango:$font $font_size

title_align center

#
# Keybindings
#

## Window management

# Kill focused window
bindsym $mod+Shift+d kill

# Enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# Change container layout
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+t floating toggle

# Toggle split direction
bindsym $mod+u split toggle

# Move windows with $mod + left mouse button, resize with $mod + right mouse button
floating_modifier $mod

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9

# Move focused window to other monitor
bindsym $mod+Shift+z move container to output left

# Resize windows
mode "resize" {
    bindsym h resize shrink width 10px
    bindsym j resize grow height 10px
    bindsym k resize shrink height 10px
    bindsym l resize grow width 10px

    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

## Focus

# Change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Switch to workspace
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9

# Swap focus between the tiling area and the floating area
bindsym $mod+o focus mode_toggle

## Scratchpad

# Move currently focused window to scratchpad
bindsym $mod+p move scratchpad

# Cycle through scratchpad windows
bindsym $mod+Shift+p scratchpad show

## System

# Reload the configuration file
bindsym $mod+Control+Shift+r reload

# Restart i3
bindsym $mod+Control+Shift+e restart

# Exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -f 'pango: $font $font_size' -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

# Lock directly
bindsym $mod+Control+l exec --no-startup-id loginctl lock-session

# Volume
bindsym XF86AudioRaiseVolume exec $sd/buttons volume_up
bindsym XF86AudioLowerVolume exec $sd/buttons volume_down
bindsym XF86AudioMute exec $sd/buttons volume_mute

# Toggle mute microphone
bindsym XF86AudioMicMute exec $sd/buttons mic_mute

# Media
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioPlay exec playerctl pause

# Screen brightness
bindsym XF86MonBrightnessUp exec $sd/buttons brightness_up
bindsym XF86MonBrightnessDown exec $sd/buttons brightness_down

# Take a screenshot of the whole screen
bindsym Print exec --no-startup-id maim -m 7 -o "/home/$USER/Pictures/screenshots/screenshot $(date '+%F %T').jpg" && notify-send "Screenshot taken"

# Take a screenshot of a selected part
bindsym Shift+Print exec --no-startup-id maim -m 7 -o --select "/home/$USER/Pictures/screenshots/screenshot $(date '+%F %T').jpg" && notify-send "Screenshot taken"

# Detect current monitor setup
bindsym $mod+y exec $sd/lid_monitor

#
# Window rules
#

# Windows that should be floating by default
for_window [class="Emacs" title="Org Capture"] floating enable
for_window [class="Bitwarden" instance="bitwarden"] floating enable
for_window [class="discord" instance="discord"] floating enable
for_window [class="Signal" instance="signal"] floating enable
for_window [class="Pavucontrol" instance="pavucontrol"] floating enable
for_window [class="Blueman-manager" instance="blueman-manager"] floating enable
for_window [class="Alacritty" instance="Alacritty"] floating enable

#
# Status bar
#

exec_always --no-startup-id $HOME/.config/polybar/launch.sh
