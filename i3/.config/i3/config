#
# System
#

# Scripts directory
set $sd ~/scripts/wm

## Background processes

# Network manager system tray icon
exec --no-startup-id nm-applet

# Bluetooth system tray item
exec --no-startup-id blueman-applet

# Pulse audio system tray item
exec --no-startup-id pasystray

# Compositing
exec --no-startup-id picom --experimental-backends

# Lock on suspend
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

# Lower brightness after 90 seconds idle,
# suspend after 2 minutes, unless in fullscreen application
exec --no-startup-id xidlehook --not-when-fullscreen --timer 90 'light -S 5' 'light -S 50' --timer 30 'light -S 50; systemctl suspend' ''

# Monitor setup
exec --no-startup-id autorandr --change

# Shuffle wallpaper
exec --no-startup-id wallshuffle

# Blue light filter
exec --no-startup-id redshift -P -O 4500

#
# Variables
#

# Modifier keys
set $mod Mod4

# Workspace names
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Font
set $font monospace
set $font_size 11


#
# Appearance
#

font pango:$font $font_size

focus_follows_mouse yes

gaps inner 0

default_border pixel 4
default_floating_border pixel 3


#
# Keybindings
#

## Window management

# Kill focused window
bindsym $mod+Shift+d kill

# Enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# Change container layout
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+t floating toggle

# Split in horizontal orientation
bindsym $mod+b split h

# Split in vertical orientation
bindsym $mod+v split v

# Move windows with $mod + left mouse button, resize with $mod + right mouse button
floating_modifier $mod

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9

# Move focused window to other monitor
bindsym $mod+Shift+z move container to output left

# Resize windows
mode "resize" {
    # left will shrink the containers width
    # right will grow the containers width
    # up will shrink the containers height
    # down will grow the containers height
    bindsym h resize shrink width 10px
    bindsym j resize grow height 10px
    bindsym k resize shrink height 10px
    bindsym l resize grow width 10px

    # Ditto, with arrow keys
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

## Focus

# Change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Swap focus between the tiling area and the floating area
bindsym $mod+space focus mode_toggle

## Scratchpad

# Move the currently focused window to the scratchpad
bindsym $mod+p move scratchpad

# Show the next scratchpad window or hide the focused scratchpad window.
# If there are multiple scratchpad windows, this command cycles through them.
bindsym $mod+Shift+p scratchpad show

## System

# Reload the configuration file
bindsym $mod+Control+Shift+r reload

# Restart i3
bindsym $mod+Control+Shift+e restart

# Exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -f 'pango: monospace 11' -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

# Lock directly
bindsym $mod+Control+l exec --no-startup-id loginctl lock-session

# Volume
bindsym XF86AudioRaiseVolume exec $sd/buttons.sh volume_up
bindsym XF86AudioLowerVolume exec $sd/buttons.sh volume_down
bindsym XF86AudioMute exec $sd/buttons.sh volume_mute

# Toggle mute microphone
bindsym XF86AudioMicMute exec $sd/buttons.sh mic_mute

# Media
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioPlay exec playerctl pause

# Screen brightness
bindsym XF86MonBrightnessUp exec $sd/buttons.sh brightness_up
bindsym XF86MonBrightnessDown exec $sd/buttons.sh brightness_down

# Take a screenshot of the whole screen
bindsym Print exec --no-startup-id maim "/home/$USER/Pictures/screenshots/screenshot $(date '+%F %T').jpg" && notify-send "Screenshot taken"

# Take a screenshot of a selected part
bindsym Shift+Print exec --no-startup-id maim --select "/home/$USER/Pictures/screenshots/screenshot $(date '+%F %T').jpg" && notify-send "Screenshot taken"

# Windows that should be floating by default
for_window [class="Emacs" instance="Global_Popup"] floating enable
for_window [class="Bitwarden" instance="bitwarden"] floating enable

## Status bar
exec_always --no-startup-id $HOME/.config/polybar/launch.sh
