defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        ~/.msmtp.log

account        fastmail
host           smtp.fastmail.com
port           465
from           martin@malon.se
user           martin@malon.se
tls_starttls   off
passwordeval   "gpg -q --for-your-eyes-only --no-tty -d ~/.authinfo.gpg"
