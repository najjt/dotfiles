command=/usr/share/i3blocks/$BLOCK_NAME
separator_block_width=15
markup=none

[mediaplayer]
instance=mpv
interval=5
signal=10

[cpu_usage]
label=CPU:
interval=10
min_width=CPU: 100.00%

[memory]
command=free -h | awk '/Mem:/ { printf("%5s \n", $3, $2) }'
label=MEM:
interval=30

[battery]
label=BAT:
interval=30

[time]
command=date '+%A %d/%m/%y %R'
interval=60
