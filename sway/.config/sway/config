### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l

set $font sans
set $font_size 10
set $sd ~/scripts

font pango:$font $font_size

focus_follows_mouse yes
focus_wrapping no
workspace_layout tabbed

set $term foot
set $menu rofi -modi "drun" -show drun -show-icons
set $clip cliphist list | rofi -dmenu | cliphist-decode | wl-copy
set $browser firefox

input type:keyboard {
    xkb_layout "se"
    repeat_rate 25
    repeat_delay 300
}

### Startup
exec_always $sd/autostart-sway

### Outputs (adjust names via: swaymsg -t get_outputs)
workspace 1 output HDMI-A-1 eDP-1
workspace 2 output HDMI-A-1 eDP-1
workspace 3 output HDMI-A-1 eDP-1
workspace 7 output eDP-1
workspace 8 output eDP-1
workspace 9 output eDP-1

### Appearance
title_align center
default_border pixel 3
gaps inner 5
gaps outer 5

### Keybindings

bindsym $mod+Return exec $term
bindsym $mod+b exec $menu
bindsym $mod+i exec $clip
bindsym $mod+n exec $browser

## Kill window
bindsym $mod+Shift+d kill

## Fullscreen
bindsym $mod+f fullscreen toggle

## Layout
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+t floating toggle

## Split toggle
bindsym $mod+u split toggle

## Floating modifier
floating_modifier $mod normal

## Move windows
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

## Move to workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9

## Move to other monitor
bindsym $mod+Shift+z move container to output left

## Resize mode
mode "resize" {
    bindsym h resize shrink width 10px
    bindsym j resize grow height 10px
    bindsym k resize shrink height 10px
    bindsym l resize grow width 10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

## Focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

## Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9

## Focus floating/tiled
bindsym $mod+o focus mode_toggle

## Scratchpad
bindsym $mod+p move scratchpad
bindsym $mod+Shift+p scratchpad show

## System
bindsym $mod+Control+Shift+r reload
bindsym $mod+Control+Shift+e restart

bindsym $mod+Shift+e exec swaynag -t warning -m "Exit sway?" -B "Yes" "swaymsg exit"

## Lock
bindsym $mod+Control+l exec swaylock -f -c 000000

## Volume (your scripts kept)
bindsym XF86AudioRaiseVolume exec $sd/buttons volume_up
bindsym XF86AudioLowerVolume exec $sd/buttons volume_down
bindsym XF86AudioMute exec $sd/buttons volume_mute
bindsym XF86AudioMicMute exec $sd/buttons mic_mute

## Media
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioPlay exec playerctl pause

## Brightness
bindsym XF86MonBrightnessUp exec $sd/buttons brightness_up
bindsym XF86MonBrightnessDown exec $sd/buttons brightness_down

## Screenshots
bindsym Print exec grim ~/Pictures/Screenshots/screenshot-$(date +'%F-%T').png
bindsym Shift+Print exec grim -g "$(slurp)" ~/Pictures/Screenshots/screenshot-$(date +'%F-%T').png

## Monitor detection
# bindsym $mod+y exec $sd/lid_monitor

### Window rules
for_window [app_id="bitwarden"] floating enable
for_window [app_id="discord"] floating enable

## Idle / lock
exec swayidle -w \
 timeout 300 'swaylock -f -c 000000' \
 timeout 600 'swaymsg "output * power off"' \
 resume 'swaymsg "output * power on"' \
 before-sleep 'swaylock -f -c 000000'
